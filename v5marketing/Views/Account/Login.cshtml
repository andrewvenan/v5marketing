@model v5marketing.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - v5marketing</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
            body {
                background: linear-gradient(135deg, #0d6efd, #0a58ca);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                width: 100%;
                max-width: 420px;
                border: none;
                border-radius: 20px;
                box-shadow: 0 20px 45px rgba(0,0,0,0.18);
            }

            .login-title {
                font-weight: 700;
                color: #0d6efd;
            }

            .subtitle {
                color: #6c757d;
            }

            .btn-login {
                border-radius: 10px;
                padding: 10px;
                font-weight: 600;
            }

            .form-control {
                border-radius: 10px;
                padding: 12px;
            }
    </style>
</head>
<body>
    <div class="card login-card p-4">
        <div class="card-body">
            <div class="text-center mb-4">
                <h2 class="login-title">v5marketing</h2>
                <p class="subtitle mb-0">Acesse o sistema com seu usuário e senha</p>
            </div>

            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger">@ViewBag.Erro</div>
            }

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Usuario" class="form-label fw-semibold">Usuário</label>
                    <input asp-for="Usuario" class="form-control" placeholder="Digite seu usuário" />
                    <span asp-validation-for="Usuario" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Senha" class="form-label fw-semibold">Senha</label>
                    <input asp-for="Senha" class="form-control" placeholder="Digite sua senha" />
                    <span asp-validation-for="Senha" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-login">Entrar</button>
            </form>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>