@model v5marketing.ViewModels.UsuarioCadastroViewModel

@{
    ViewData["Title"] = "Cadastrar Usuário";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h2 class="fw-bold mb-1">Cadastro de Usuário</h2>
                    <p class="text-muted mb-0">Preencha os dados abaixo para cadastrar um novo usuário.</p>
                </div>
                <a asp-action="Index" class="btn btn-outline-secondary">Voltar</a>
            </div>

            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" class="row g-3">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="col-md-6">
                            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
                            <input asp-for="Nome" class="form-control" />
                            <span asp-validation-for="Nome" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Email" class="form-label fw-semibold">E-mail</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Login" class="form-label fw-semibold">Login</label>
                            <input asp-for="Login" class="form-control" />
                            <span asp-validation-for="Login" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Perfil" class="form-label fw-semibold">Perfil</label>
                            <select asp-for="Perfil" class="form-select">
                                <option value="Administrador">Administrador</option>
                                <option value="Operador">Operador</option>
                            </select>
                            <span asp-validation-for="Perfil" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Senha" class="form-label fw-semibold">Senha</label>
                            <input asp-for="Senha" class="form-control" />
                            <span asp-validation-for="Senha" class="text-danger"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="ConfirmarSenha" class="form-label fw-semibold">Confirmar Senha</label>
                            <input asp-for="ConfirmarSenha" class="form-control" />
                            <span asp-validation-for="ConfirmarSenha" class="text-danger"></span>
                        </div>

                        <div class="col-md-4">
                            <label asp-for="Ativo" class="form-label fw-semibold">Status</label>
                            <select asp-for="Ativo" class="form-select">
                                <option value="true">Ativo</option>
                                <option value="false">Inativo</option>
                            </select>
                            <span asp-validation-for="Ativo" class="text-danger"></span>
                        </div>

                        <div class="col-12 mt-4 d-flex gap-2">
                            <button type="submit" class="btn btn-success px-4">Salvar</button>
                            <a asp-action="Index" class="btn btn-secondary px-4">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}