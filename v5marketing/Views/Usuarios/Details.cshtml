@model v5marketing.Models.Usuario

@{
    ViewData["Title"] = "Detalhes";
}

<h2 class="mb-4">Detalhes do Usuário</h2>

<div class="card shadow-sm">
    <div class="card-body">

        <p><strong>Nome:</strong> @Model.Nome</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Login:</strong> @Model.Login</p>
        <p><strong>Perfil:</strong> @Model.Perfil</p>
        <p><strong>Status:</strong> @(Model.Ativo ? "Ativo" : "Inativo")</p>
        <p><strong>Criado em:</strong> @Model.DataCriacao.ToString("dd/MM/yyyy HH:mm")</p>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
            <a asp-action="Index" class="btn btn-secondary">Voltar</a>
        </div>

    </div>
</div>